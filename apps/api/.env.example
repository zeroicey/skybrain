# ---------------------------------------------
# SkyBrain API environment template
# Copy this file to .env (or .env.development) and fill real values.
# ---------------------------------------------

# Runtime
NODE_ENV=development
PORT=3000

# Database
# Option A: use a full connection string
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skybrain

# Option B: use segmented fields (required when DATABASE_URL is not set)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=skybrain

# JWT
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=7d

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=skybrain
MINIO_USE_SSL=false
